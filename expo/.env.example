# AI Longevity Pro — Environment Variables
# Copy this to .env and fill in your values.

# ── Supabase ──────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Junction / Vital (wearable data) ─────────────────────────
# API key from the Junction (Vital) dashboard — used by the webhook
# edge function and server-side calls. NEVER ship in the client bundle.
JUNCTION_API_KEY=

# Webhook signing secret — used by the edge function to verify
# incoming webhook payloads from Junction.
JUNCTION_WEBHOOK_SIGNING_SECRET=

# Environment: 'sandbox' for dev, 'production' for prod.
EXPO_PUBLIC_VITAL_ENVIRONMENT=sandbox

# Your Vital API key (client-side — used by the Vital SDK to
# initialize the link widget). This is the publishable key, not the secret.
EXPO_PUBLIC_VITAL_API_KEY=

# ── Token encryption (Supabase Vault or manual) ──────────────
# Used by pgcrypto to encrypt wearable provider tokens at rest.
# In Supabase Vault environments, use Vault instead of this var.
WEARABLE_TOKEN_ENCRYPTION_KEY=

# ── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Passio (nutrition) ───────────────────────────────────────
PASSIO_API_KEY=
